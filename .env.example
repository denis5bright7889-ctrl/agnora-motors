# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local — it is already in .gitignore.

# ── Database (Neon PostgreSQL) ──────────────────────────────
# Get from: https://neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── NextAuth v5 ──────────────────────────────────────────────
# Generate: openssl rand -base64 32
# AUTH_SECRET is the canonical v5 name; NEXTAUTH_SECRET kept as fallback.
AUTH_SECRET=your-random-secret-here
NEXTAUTH_SECRET=your-random-secret-here

# AUTH_URL MUST be set in Vercel for custom domains.
# Vercel auto-detects the URL for *.vercel.app deployments, but for a custom
# domain (agnora-motors.com) you must set this explicitly in Vercel →
# Settings → Environment Variables, otherwise OAuth callbacks use the wrong
# origin and Google authentication loops back to the login page.
#
# Local dev:
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# Production (set in Vercel dashboard, not committed):
# AUTH_URL=https://agnora-motors.com
# AUTH_TRUST_HOST=1

# ── Google OAuth ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
#
# Authorized redirect URIs — add ALL of these in Google Console:
#   http://localhost:3000/api/auth/callback/google      (local dev)
#   https://<project>.vercel.app/api/auth/callback/google  (preview)
#   https://agnora-motors.com/api/auth/callback/google  (production)
#
# Authorized JavaScript origins:
#   http://localhost:3000
#   https://agnora-motors.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Cloudinary (image uploads) ──────────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Admin credentials ─────────────────────────────────────────
# Generate hash: node -e "require('bcryptjs').hash('YourPassword', 12).then(console.log)"
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD_HASH=bcrypt-hash-of-your-password
ADMIN_NAME=Your Admin Name

# ── Resend (transactional email / OTP delivery) ──────────────────────────
# Get from: https://resend.com → API Keys → Create API Key
# The key must have "Send Email" permission.
# CRITICAL: also add this to Vercel → Settings → Environment Variables
# (it is NOT in .env.local by default — if missing, OTP emails will never send)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

#── NewsPub API Key (for fetching car news) ──────────────────────────────
NEWSAPI_KEY=        # newsapi.org free tier (100 req/day)
GNEWS_KEY=          # gnews.io free tier (100 req/day)
CRON_SECRET=        # any secret string — protects cron endpoints
NEXT_PUBLIC_BASE_URL=https://agnora-motors.com
